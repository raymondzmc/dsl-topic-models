# Copy this file to `.env` and fill in the values you need.
# NONE of these are required to train baselines or DSL models and write local results.
# They are only needed for the features noted below.

# --- OpenAI (optional) ---
# Needed for: the `LLM` topic-coherence rating metric (gpt-4o) and vocabulary
# embeddings used by some diversity metrics.
# Omit it (or pass --skip_llm_rating) to train/evaluate without LLM ratings.
OPENAI_API_KEY=

# --- Hugging Face (optional) ---
# Needed for: downloading the pre-processed soft-label datasets from the Hub, and
# (only if you set --no_upload off) uploading datasets you process yourself.
HF_TOKEN=
HF_USERNAME=

# --- Weights & Biases (optional) ---
# Needed ONLY if you pass `--wandb` to dsl-train. By default results are written
# to ./results/ as local JSON and W&B is never contacted.
WANDB_API_KEY=
WANDB_ENTITY=

# --- Optional cache-directory overrides (leave blank to use defaults) ---
# DSL_TOPIC_DATA_DIR=   # where processed_data/ and wikipedia/ live (default: ./data)
# HF_HOME=
# TRANSFORMERS_CACHE=
# WANDB_DIR=
# WANDB_CACHE_DIR=
# WANDB_DATA_DIR=
# NUMBA_CACHE_DIR=
